# Import libraries
import pandas as pd
from sklearn.preprocessing import StandardScaler

# -----------------------------
# DIABETES DATASET
# -----------------------------

# Load the dataset
diabetes = pd.read_csv("diabetes.csv")

# Check for missing values
print("Diabetes Missing Values:")
print(diabetes.isnull().sum())

# Remove duplicate rows
diabetes = diabetes.drop_duplicates()

# Separate features and target
X_diabetes = diabetes.drop("Outcome", axis=1)
y_diabetes = diabetes["Outcome"]

# Scale the features
scaler = StandardScaler()
X_diabetes_scaled = scaler.fit_transform(X_diabetes)

# Convert scaled data back to DataFrame
X_diabetes_scaled = pd.DataFrame(X_diabetes_scaled, columns=X_diabetes.columns)

# Add the target column
diabetes_cleaned = X_diabetes_scaled
diabetes_cleaned["Outcome"] = y_diabetes.values

# Save cleaned dataset
diabetes_cleaned.to_csv("diabetes_cleaned.csv", index=False)

print("Diabetes dataset cleaned and saved successfully!")

